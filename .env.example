# FreshTrack Configuration
# Copy this file to .env and fill in your values

# Flask Environment
FLASK_ENV=development
# Set to 'production' for production deployment (debug mode will be disabled)

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/freshtrack
MONGO_DB_NAME=freshtrack

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production

# ML Model Path (absolute path to inventory-ai/ml directory)
# Leave empty to use auto-detection
ML_MODEL_PATH=

# CORS Configuration
CORS_ALLOW_ORIGINS=http://localhost:5173
# For production: CORS_ALLOW_ORIGINS=https://yourdomain.com

# Optional: OCR Tesseract Path (for Windows/custom installations)
# TESSDATA_PREFIX=C:/Program Files/Tesseract-OCR/tessdata
